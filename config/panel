# lxpanel <profile> config file. Manually editing is not recommended.
# Use preference dialog in lxpanel to adjust config when you can.

Global {
  edge=bottom
  align=right
  margin=0
  widthtype=percent
  width=100
  height=34
  transparent=0
  tintcolor=#000000
  alpha=0
  autohide=1
  heightwhenhidden=0
  autohidedelay=2000
  setdocktype=1
  setpartialstrut=1
  usefontcolor=0
  fontsize=12
  fontcolor=#ffffff
  usefontsize=0
  background=0
  backgroundfile=/usr/share/lxpanel/images/background.png
  iconsize=24
  monitor=0
  point_at_menu=0
  notifications=0
}
